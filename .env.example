# ─────────────────────────────────────────────────────────────────────────────
# DJANGO CORE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-generate-with-django-utils
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION (for production on Vercel)
# ─────────────────────────────────────────────────────────────────────────────
# Leave blank to use SQLite locally, or provide PostgreSQL URL in production
DATABASE_URL=postgresql://user:password@host:5432/iri_collections

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE PAYMENT GATEWAY
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY & CORS (Required for production on Vercel)
# ─────────────────────────────────────────────────────────────────────────────
PROD_DOMAINS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY HEADERS (HTTPS & Cookies)
# ─────────────────────────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (for notifications)
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ─────────────────────────────────────────────────────────────────────────────
# AWS S3 (OPTIONAL - for media storage instead of local disk)
# ─────────────────────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
