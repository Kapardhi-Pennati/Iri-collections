{
  "version": 2,
  "buildCommand": "python manage.py collectstatic --no-input && python manage.py migrate",
  "outputDirectory": "staticfiles",
  "functions": {
    "api/wsgi.py": {
      "runtime": "@vercel/python"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": {
        "Cache-Control": "max-age=31536000, immutable"
      }
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/wsgi.py"
    }
  ]
}
